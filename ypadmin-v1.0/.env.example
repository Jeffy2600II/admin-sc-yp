# YP Admin — Environment Variables
# Copy to .env.local (Vercel) or .env (local dev) and fill in real values.

# ─── Supabase (required) ────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
# Both ypadmin and yplabs/ypwork share the SAME Supabase project.

# Browser-safe (publishable) — used by client components
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — used by Route Handlers / Server Actions (bypasses RLS)
# KEEP SECRET — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional aliases (server-side canonical names)
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=YOUR-ANON-KEY
